<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Panel id="quizSourcePanel" class="quizSourcePanel sapUiMediumMarginBottom" expandable="true" expanded="true" headerText="{i18n>quizInputHeader}">
        <VBox id="quizSourcePanelContent" class="quizSourcePanelContent">
            <Text id="quizInputEyebrow" text="{i18n>quizInputEyebrow}" class="quizEyebrow" />
            <Title id="quizInputTitle" text="{i18n>loadQuestionsTitle}" level="H2" class="quizSectionTitle" />
            <Text
                id="quizInputDescription"
                text="{i18n>quizInputDescription}"
                wrapping="true"
                class="quizMutedText" />

            <MessageStrip
                id="quizInputFeedback"
                text="{quiz>/inputFeedbackMessage}"
                type="{quiz>/inputFeedbackType}"
                visible="{= !!${quiz>/inputFeedbackMessage} }"
                showIcon="true"
                class="sapUiSmallMarginTop" />

            <VBox id="quizJsonGroup" class="quizFieldGroup sapUiMediumMarginTop">
                <HBox id="quizJsonGroupHeader" justifyContent="SpaceBetween" alignItems="Center">
                    <Label id="quizJsonLabel" text="{i18n>pasteJsonLabel}" labelFor="quizJsonInput" />
                    <Text id="quizJsonHint" text="{i18n>jsonHint}" class="quizHint" />
                </HBox>
                <TextArea
                    id="quizJsonInput"
                    rows="15"
                    growing="false"
                    height="260px"
                    width="100%"
                    placeholder="{i18n>jsonPlaceholder}" />
                <HBox id="quizJsonActions" class="quizActionRow" wrap="Wrap" justifyContent="Start">
                    <Button id="loadJsonQuizButton" text="{i18n>loadJsonQuiz}" type="Emphasized" press=".onLoadQuizFromJson" />
                    <Button id="demoJsonButton" text="{i18n>loadDemoJson}" type="Transparent" press=".onUseDemoQuiz" />
                    <Button id="clearInputsButton" text="{i18n>clear}" type="Ghost" press=".onClearQuizInputs" />
                </HBox>
            </VBox>

            <VBox id="quizUrlGroup" class="quizFieldGroup sapUiMediumMarginTop">
                <Label id="quizUrlLabel" text="{i18n>quizUrlLabel}" labelFor="quizApiUrlInput" />
                <Input
                    id="quizApiUrlInput"
                    placeholder="{i18n>quizUrlPlaceholder}"
                    type="Url"
                    width="100%" />
                <Button id="loadUrlQuizButton" text="{i18n>loadFromUrl}" press=".onLoadQuizFromUrl" width="100%" />
            </VBox>

            <Button id="sampleQuizButton" text="{i18n>resetSampleQuiz}" type="Transparent" press=".onRestartQuiz" class="sapUiSmallMarginTop" />
        </VBox>
    </Panel>

</core:FragmentDefinition>