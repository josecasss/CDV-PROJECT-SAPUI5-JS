<mvc:View
    controllerName="quizzapp.cdvproject.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">

    <Page id="page" title="SAP Quiz Challenge" class="quizPage">
        <content>
            <VBox id="quizShell" class="sapUiContentPadding quizShell">
                <core:Fragment fragmentName="quizzapp.cdvproject.view.QuizInput" type="XML" />

                <VBox id="quizCard" class="quizCard" busy="{quiz>/loading}" busyIndicatorDelay="0">
                    <VBox id="quizInProgressPanel" visible="{= !${quiz>/quizCompleted} }">
                        <VBox id="quizHeader" class="quizHeader sapUiSmallMarginBottom">
                            <Text id="quizHeaderEyebrow" text="Interactive SAP knowledge quiz" class="quizEyebrow" />
                            <Title id="quizHeaderTitle" text="SAP Quiz Challenge" level="H1" class="quizTitle" />
                            <Text
                                id="quizHeaderDescription"
                                text="{i18n>quizDescription}"
                                wrapping="true"
                                class="quizMutedText" />
                            <HBox id="quizHeaderStats" class="quizStatsRow" justifyContent="Start" alignItems="Center">
                                <ObjectStatus id="quizProgressChip" text="{quiz>/progressText}" state="Success" />
                                <ObjectStatus id="quizScoreChip" text="{= ${i18n>scoreLabel} + ' ' + ${quiz>/score} + '/' + ${quiz>/totalQuestions} }" state="Information" />
                            </HBox>
                        </VBox>

                        <VBox id="quizProgressContainer" class="quizProgress sapUiMediumMarginBottom">
                            <ProgressIndicator
                                id="quizProgressIndicator"
                                percentValue="{quiz>/progressValue}"
                                displayValue="{quiz>/progressText}"
                                state="Success" />
                        </VBox>

                        <VBox id="questionBlock" class="sapUiSmallMarginBottom">
                            <Title id="currentQuestionTitle" text="{quiz>/currentQuestion/question}" level="H2" class="quizQuestion" wrapping="true" />
                            <Text id="questionPrompt" text="Choose the best answer:" class="quizMutedText sapUiTinyMarginTop" />
                        </VBox>

                        <List id="quizAnswers" class="quizAnswers" items="{quiz>/currentQuestion/options}" showSeparators="None" inset="false">
                            <CustomListItem id="answerListItemTemplate">
                                <Button id="answerButtonTemplate"
                                    text="{quiz>}"
                                    press=".onAnswerPress"
                                    width="100%"
                                    enabled="{= !${quiz>/quizCompleted} }" />
                            </CustomListItem>
                        </List>
                    </VBox>

                    <VBox id="quizResults" visible="{quiz>/quizCompleted}" class="quizResults">
                        <Text id="quizResultsEyebrow" text="Quiz completed" class="quizEyebrow" />
                        <Title id="quizResultsTitle" text="{i18n>yourResults}" level="H1" class="quizTitle" />
                        <Text id="quizResultsMessage" text="{quiz>/resultMessage}" wrapping="true" class="quizMutedText" />

                        <HBox id="quizScoreRow" class="quizScoreRow sapUiMediumMarginTop sapUiMediumMarginBottom" justifyContent="SpaceBetween" alignItems="Center">
                            <ObjectNumber id="quizScoreNumber" number="{quiz>/score}" unit="correct answers" state="Success" />
                            <Text
                                id="quizScoreHint"
                                text="{= ${quiz>/score} === ${quiz>/totalQuestions} ? ${i18n>perfectScore} : ${i18n>reviewMissedAnswers} }"
                                wrapping="true"
                                class="quizMutedText" />
                        </HBox>

                        <List id="quizResultsList" items="{quiz>/review}" class="quizResultsList" inset="false">
                            <CustomListItem id="reviewListItem">
                                <VBox id="reviewItem" class="quizReviewItem">
                                    <HBox id="reviewItemHeader" justifyContent="SpaceBetween" alignItems="Start">
                                        <Title id="reviewQuestionNumber" text="{= 'Question ' + ${quiz>questionNumber} }" level="H4" />
                                        <ObjectStatus
                                            id="reviewStatus"
                                            text="{= ${quiz>isCorrect} ? 'Correct' : 'Incorrect' }"
                                            state="{= ${quiz>isCorrect} ? 'Success' : 'Error' }" />
                                    </HBox>
                                    <Text id="reviewQuestionText" text="{quiz>question}" wrapping="true" />
                                    <Text id="reviewSelectedAnswer" text="{= 'Your answer: ' + ${quiz>selectedAnswer} }" wrapping="true" />
                                    <Text id="reviewCorrectAnswer" text="{= 'Correct answer: ' + ${quiz>correctAnswer} }" wrapping="true" />
                                    <Text id="reviewExplanation" text="{quiz>explanation}" wrapping="true" class="quizMutedText" />
                                </VBox>
                            </CustomListItem>
                        </List>

                        <Button id="restartQuizButton" text="{i18n>restartQuiz}" type="Emphasized" press=".onRestartQuiz" class="sapUiMediumMarginTop" />
                    </VBox>
                </VBox>
            </VBox>
        </content>
    </Page>
</mvc:View>